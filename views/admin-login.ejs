<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — ShieldHub</title>
  <link rel="stylesheet" href="/css/style.css?v=<%= Date.now() %>">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body style="background:#060612;">

<div class="admin-login-page">
  <!-- LEFT PANEL -->
  <div class="admin-login-left">
    <div class="admin-login-left-content">
      <div class="admin-login-shield animate-float">
        <i class="fas fa-shield-halved"></i>
      </div>
      <h1 class="admin-login-tagline">Welcome to<br><span>ShieldHub</span> Admin</h1>
      <p class="admin-login-sub">Secure control panel for managing your cybersecurity platform.</p>

      <div class="admin-login-features">
        <div class="admin-login-feature">
          <div class="admin-login-feature-icon"><i class="fas fa-newspaper"></i></div>
          <span>Manage articles &amp; cybercrime news</span>
        </div>
        <div class="admin-login-feature">
          <div class="admin-login-feature-icon"><i class="fas fa-circle-question"></i></div>
          <span>Create and edit quiz questions</span>
        </div>
        <div class="admin-login-feature">
          <div class="admin-login-feature-icon"><i class="fas fa-chart-bar"></i></div>
          <span>View site statistics at a glance</span>
        </div>
        <div class="admin-login-feature">
          <div class="admin-login-feature-icon"><i class="fas fa-lock"></i></div>
          <span>Protected with CAPTCHA &amp; sessions</span>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL -->
  <div class="admin-login-right">
    <div class="admin-login-form-wrap">
      <div class="admin-login-header">
        <div class="admin-login-logo">
          <div style="width:40px;height:40px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;color:#fff;box-shadow:0 4px 16px rgba(99,102,241,0.4);">
            <i class="fas fa-shield-alt"></i>
          </div>
          <span style="font-family:'Outfit',sans-serif;font-size:18px;font-weight:800;color:#f1f5f9;">Shield<span style="background:linear-gradient(135deg,#818cf8,#22d3ee);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">Hub</span></span>
        </div>
        <h2 class="admin-login-title">Sign In</h2>
        <p class="admin-login-desc">Enter your credentials to access the admin panel.</p>
      </div>

      <!-- Error Alert -->
      <% if (error) { %>
        <div class="admin-alert admin-alert-danger">
          <i class="fas fa-triangle-exclamation"></i> <%= error %>
        </div>
      <% } %>

      <form method="POST" action="/admin/login" id="loginForm">
        <!-- Username -->
        <div class="floating-label-group">
          <input type="text" name="username" id="username" class="admin-form-input" placeholder=" " required autocomplete="username">
          <label for="username" class="floating-label">Username</label>
          <i class="fas fa-user input-icon"></i>
        </div>

        <!-- Password -->
        <div class="floating-label-group">
          <input type="password" name="password" id="password" class="admin-form-input" placeholder=" " required autocomplete="current-password" style="padding-right:48px;">
          <label for="password" class="floating-label">Password</label>
          <button type="button" id="togglePass" style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:#334155;cursor:pointer;font-size:15px;padding:0;" tabindex="-1">
            <i class="fas fa-eye" id="eyeIcon"></i>
          </button>
        </div>

        <!-- CAPTCHA -->
        <div class="captcha-box">
          <i class="fas fa-robot" style="color:#475569;font-size:18px;"></i>
          <div class="captcha-nums"><%= captchaNum1 %> + <%= captchaNum2 %></div>
          <div class="captcha-eq">=</div>
          <input type="number" name="captchaAnswer" class="captcha-input" placeholder="?" required min="2" max="20" id="captchaAnswer">
          <input type="hidden" name="captchaNum1" value="<%= captchaNum1 %>">
          <input type="hidden" name="captchaNum2" value="<%= captchaNum2 %>">
        </div>

        <button type="submit" class="login-submit-btn" id="loginBtn">
          <i class="fas fa-right-to-bracket"></i>
          <span>Sign In to Dashboard</span>
        </button>
      </form>

      <div style="text-align:center;">
        <a href="/admin/forgot-password" style="font-size:13px;color:#475569;text-decoration:none;transition:color 0.2s;"
           onmouseover="this.style.color='#818cf8'" onmouseout="this.style.color='#475569'">
          <i class="fas fa-unlock-keyhole"></i> Forgot credentials? Use recovery key
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // Password toggle
  document.getElementById('togglePass').addEventListener('click', function(){
    const p = document.getElementById('password');
    const eye = document.getElementById('eyeIcon');
    if(p.type === 'password'){
      p.type = 'text';
      eye.className = 'fas fa-eye-slash';
      this.style.color = '#6366f1';
    } else {
      p.type = 'password';
      eye.className = 'fas fa-eye';
      this.style.color = '#334155';
    }
  });

  // Submit animation
  document.getElementById('loginForm').addEventListener('submit', function(){
    const btn = document.getElementById('loginBtn');
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> <span>Signing in...</span>';
    btn.style.opacity = '0.8';
    btn.style.pointerEvents = 'none';
  });
</script>
</body>
</html>